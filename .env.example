# StockTracker Environment Variables

# Alpha Vantage API Key (免费，额度: 5次/分钟, 500次/天)
# 注册地址: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=YOUR_API_KEY_HERE
# 兼容旧配置（可选，不推荐）
NEXT_PUBLIC_ALPHA_VANTAGE_API_KEY=

# FinnHub API Key (备选，免费额度更高: 60次/分钟)
# 注册地址: https://finnhub.io/dashboard
NEXT_PUBLIC_FINNHUB_API_KEY=YOUR_API_KEY_HERE

# 注意：
# 1. 将此文件重命名为 .env.local
# 2. 从对应网站免费注册获取API Key
# 3. MVP阶段只需配置Alpha Vantage即可
# 4. 优先使用服务端变量 ALPHA_VANTAGE_API_KEY，避免 Key 暴露到前端
