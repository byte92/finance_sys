# StockTracker Environment Variables

# Alpha Vantage API Key (免费，额度: 5次/分钟, 500次/天)
# 注册地址: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=YOUR_API_KEY_HERE
# 兼容旧配置（可选，不推荐）
NEXT_PUBLIC_ALPHA_VANTAGE_API_KEY=

# AI 模型配置（推荐放在 .env.local，避免密钥进入 SQLite / JSON 备份）
# AI_PROVIDER:
# - openai-compatible：OpenAI Chat Completions 兼容接口，例如 OpenAI、DeepSeek、Qwen、OpenRouter、部分本地网关
# - anthropic-compatible：Anthropic Messages 兼容接口，例如 Claude API 或兼容网关
AI_PROVIDER=openai-compatible

# AI_BASE_URL:
# - openai-compatible 示例：https://api.openai.com/v1
# - anthropic-compatible 示例：https://api.anthropic.com/v1
# - 也可以填写兼容服务商或本地网关地址，例如 http://localhost:11434/v1
AI_BASE_URL=https://api.openai.com/v1

# AI_MODEL:
# - 模型名称由服务商决定，例如 gpt-4.1-mini、deepseek-chat、qwen-plus、claude-3-5-sonnet-latest
AI_MODEL=

# AI_API_KEY:
# - 服务端使用，不会暴露给浏览器；真实密钥请只写在 .env.local
AI_API_KEY=

# 注意：
# 1. 将此文件重命名为 .env.local
# 2. 从对应网站获取 API Key
# 3. 优先使用服务端变量 ALPHA_VANTAGE_API_KEY / AI_API_KEY，避免 Key 暴露到前端
